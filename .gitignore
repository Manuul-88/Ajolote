# ==========================================
# Unity .gitignore Template (Mejorado por null2)
# ==========================================

# Carpetas generadas por Unity
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Archivos de registro y crash
*.log
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# Archivos de Blender (Backups automáticos)
*.blend1
*.blend1.meta

# Capturas y Grabaciones (Pueden pesar gigabytes)
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ==========================================
# IDEs y Editores de Código
# ==========================================

# Visual Studio / Visual Studio Code
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# Gradle / Consulo
.gradle/
ExportedObj/
.consulo/

# Meta archivos generados por Unity para IDEs
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ==========================================
# Builds y Paquetes
# ==========================================
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# ==========================================
# Addressables y Visual Scripting
# ==========================================
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Pruebas automatizadas
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ==========================================
# Archivos Basura del Sistema Operativo
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
